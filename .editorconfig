root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 100

[*.{md,markdown}]
trim_trailing_whitespace = false
max_line_length = off

[*.{yml,yaml,json}]
indent_size = 2

[CMakeLists.txt]
indent_size = 2

[*.cmake]
indent_size = 2
